# Frontend (Vite) — copy to `.env` in repo root. Rebuild after changing.

# API + WebSocket: dev default is http://localhost:4000
# Production on same VM as nginx: omit both so the SPA uses same origin as the page.
# VITE_API_BASE_URL=
# VITE_SOCKET_URL=

# Optional: public URL for invite links if it differs from where the user opened the app
# VITE_PUBLIC_APP_URL=https://your-vm.example.com

# Dev server port (see vite.config.ts)
# VITE_DEV_PORT=5729
