# Copy to .env and fill in values. Never commit .env.

# Required
JWT_SECRET=
# At least one Gemini key (see env-validator.js for alternate names)
GEMINI_API_KEY=

# Server
PORT=4000
# Listen address (0.0.0.0 = all interfaces — required on Oracle Cloud / Docker)
HOST=0.0.0.0
NODE_ENV=development
# Match your Vite dev origin (see root vite.config.ts, often :5729). Production on VM: https://your-vm.example.com
CORS_ORIGIN=http://localhost:5729
# Reverse proxy: TRUST_PROXY=0 | 1 | true, or TRUST_PROXY_HOPS=2 for chained LBs (default: 1 hop)
# TRUST_PROXY=1
# TRUST_PROXY_HOPS=1
# HTTP server timeouts (ms)
# REQUEST_TIMEOUT_MS=120000
# HEADERS_TIMEOUT_MS=125000
# KEEP_ALIVE_TIMEOUT_MS=65000
# Production: chat/question bodies are omitted from logs unless you set LOG_MULTIPLAYER_CONTENT=1
# LOG_MULTIPLAYER_CONTENT=

# Database: omit DATABASE_URL to use SQLite under ./data/
# DATABASE_URL=postgres://USER:PASSWORD@host:5432/dbname
# PG_POOL_MAX=20
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=10000

# Monitoring / ops
# LOG_DIR=./logs
# STATS_LOG_INTERVAL_MS=300000
# MEMORY_ALERT_HEAP_MB=384
# HEALTH_MEMORY_LIMIT_MB=1536
# METRICS_SECRET=  # if set, GET /metrics requires Authorization: Bearer <secret> or ?token=
# LOG_HTTP_VERBOSE=1

# Optional: Supabase for hosted auth / multiplayer sync
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Production: required for POST /api/maintenance/cleanup and GET /api/maintenance/size
# Send header: X-Maintenance-Key: <same value>
# MAINTENANCE_SECRET=
